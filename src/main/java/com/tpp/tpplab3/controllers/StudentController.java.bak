package com.tpp.tpplab3.controllers;

import com.tpp.tpplab3.models.Student;
import com.tpp.tpplab3.repository.StudentRepository;
import org.springframework.stereotype.Controller; // ВАЖЛИВО: просто @Controller
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestParam;

import java.util.List;

@Controller // Ця анотація дозволяє повертати HTML-сторінки
public class StudentWebController {

    private final StudentRepository repository;

    public StudentWebController(StudentRepository repository) {
        this.repository = repository;
    }

    // 1. Головна сторінка студентів (показує всіх)
    @GetMapping("/students")
    public String showStudents(Model model) {
        List<Student> students = repository.findAll();
        model.addAttribute("students", students);
        return "search"; // Відкриває файл search.html
    }

    // 2. Пошук студентів (той, що у формі в search.html)
    @GetMapping("/students/search")
    public String searchStudents(@RequestParam("lastName") String lastName, Model model) {
        List<Student> students;
        if (lastName != null && !lastName.isEmpty()) {
            students = repository.findByLastNameInsecure(lastName);
        } else {
            students = repository.findAll();
        }
        model.addAttribute("students", students);
        return "search"; // Знову повертаємо на ту саму сторінку, але з результатами пошуку
    }
}